              <source srcset="/sites/defesa-civil/arquivos_restritos/files/styles/escala_940_largura_/public/imagem/2024-03/kit_de_emergencia_pessoal.png?itok=0HkjekWE 1x" media="(max-width: 1199px) and (min-width: 992px)" type="image/png"></source>
