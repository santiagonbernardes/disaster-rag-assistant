			<style class="wpcode-css-snippet">@keyframes btnnext {
	0%   {top: 6px;}
	50%   {top: 0px;}
	100%  {top:8px;}
}
.hidden-desktop {
		display: none;
		visibility: hidden;
	}
.bigtext {
	font-size: 35px;
	font-weight: 800;
}
#btnNavigationNext{
  position: relative;
  animation-name: btnnext;
  animation-duration: .7s;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}
#saibamais-previsao span.red,
 span.red {
	color: #ff0000 !important;
}
#spsemfogo span.space {
	margin-left: 123px!important;
}

/* Alertas Home */
.secao-alertas {
	display: flex;
	flex-wrap: nowrap;
	align-items: stretch;
	justify-content: center;
	gap: 25px;
	column-gap: 25px;
}
.alertas-box {
	position: relative;
	padding: 10px;
	border: 1px solid #222222;
	border-radius: 20px;
	background: #FFFFFF;
	display: flex;
	flex-direction: column;
	max-width: 480px;
	width: 100%;
	min-height: 160px;
}
.alertas-box .alerta-titulo img {
	position: absolute;
	right: -20px;
	top: -22px;
	z-index: 2;
	width: auto;
	height: auto;
	max-width: 60px;
	max-height: 74px
}

.alertas-box .alerta-titulo img.margin-icone-gravidade-maior {
	top: -40px;
}


.alertas-box .alerta-titulo {
	display: flex;
	align-items: center;
	justify-content: center;
	border-bottom: 1px solid #222222;
	padding: 10px 15px;
	margin:0;
}
.alertas-box .alerta-titulo p {
	text-align: center;
	font-family: "Roboto", Sans-serif;
	font-size: 17px;
	font-weight: 800;
	text-transform: uppercase;
	letter-spacing: 0.5px;
	color: #FF0000;
	padding: 0;
	margin: 0;
	line-height: 1;
}
.alerta-conteudo {
	align-items: start;
	padding: 5px 10px;
	padding-bottom: 0;
}
.alerta-conteudo p {
	font-family: "Montserrat", Sans-serif;
	font-size: 16px;
	font-weight: 500;
	color: #000000;
}
a.botoes-alertas {
	display: flex;
	justify-content: center;
	font-family: "Montserrat", Sans-serif;
	color: #000000;
	font-size: 14px;
	font-weight: 700;
	text-align: center;
	padding-bottom: 8px;
}
.botoes-alertas span.red {
	padding-left: 3px;
}

/* Sp Sem Fogo */
#operacao-spsemfogo sup {
	font-size: 18px;
}
.texto-red {
	color: #FF0000!important;
}
.virgula-bignumbers {
	font-size: 22px;
	font-family: "Verdana", Sans-serif!important;
}
#icone-alertas-interno img {
	z-index: 3;
	width: auto;
	height: auto;
	max-width: 155px;	
	max-height: 190px;
	margin-top: -50px;
	margin-right: -50px;
}
#icone-alertas-interno img.margin-icone-gravidade-maior {
	margin-top: -86px;
}

/* ORIENTAÇÕES INTERNAS */

.conteudo-orientacoes-interna h2 {
	font-weight: 800;
	font-size: 28px;
	text-transform: uppercase;
	margin: 45px auto 0 auto;
	text-align: center;
}

/* seção botoes orientações */
.secao-botoes-orientacoes .botao-orientacao a,
.secao-botoes-orientacoes {
	text-decoration: normal;
}

.secao-botoes-orientacoes .botao-orientacao:hover p {
	text-decoration: underline;
	color: #FF0000;
}

@media (max-width: 780px) {
	.alertas-box {
		width: 86%;
		min-height: 150px;
	}
	.secao-alertas {
		display: flex;
		flex-direction: column;
		align-content: center;
		flex-wrap: wrap;
		}
	.hidden-desktop {
		display: block;
		visibility: visible;
	}
	.hidden-mobile {
		display: none;
		visibility: hidden;
	}
	.secao-botoes-orientacoes .botao-orientacao a,
	.secao-botoes-orientacoes {
		font-size: 13px!important;
	}
	#icone-alertas-interno img {
		position: absolute;
		left: 0;
		right: 0;
	    margin: auto;
		margin-top: -70px;
	}
	.conteudo-orientacoes-interna h2 {
		font-size: 26px;
		margin: 45px auto 0 auto;
	}
}</style><link rel="icon" href="https://www.spsemprealerta.sp.gov.br/wp-content/uploads/2024/11/favicon.png" sizes="32x32" />
